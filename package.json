{
  "name": "yourmascotnow",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "assets:extract-chatgpt": "node scripts/extract-chatgpt-sheets.mjs",
    "assets:vectorize": "node scripts/vectorize-assets.mjs",
    "assets:sync": "node scripts/sync-assets.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
    "@fontsource-variable/commissioner": "^5.3.0",
    "@fontsource/atkinson-hyperlegible-next": "^5.3.0",
    "@fontsource/knewave": "^5.3.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tanstack/eslint-config": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.7.0",
    "potrace": "^2.1.8",
    "prettier": "^3.8.1",
    "sharp": "^0.35.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "sharp"
    ]
  }
}
